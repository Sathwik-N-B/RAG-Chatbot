# 🌐 LLM Configuration - Choose between Ollama (local) or NVIDIA (online)

# ===============================================
# 📦 OLLAMA Configuration (Local LLM)
# ===============================================
# Make sure Ollama is running on your machine
# Default: http://localhost:11434
OLLAMA_API_URL=http://127.0.0.1:11434

# Model to use with Ollama
# Available models: qwen2.5, mistral, llama2, neural-chat, etc.
# Install a model first: ollama pull <model-name>
MODEL=qwen2.5:1.5b

# ===============================================
# 🌐 NVIDIA Configuration (Online LLM)
# ===============================================
# Get your API key from: https://build.nvidia.com/
# Sign up at: https://build.nvidia.com/
# IMPORTANT: Keep this key secret and never commit it to git!
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# NVIDIA OpenAI-compatible base URL
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# NVIDIA model to use
# Example: z-ai/glm-5.1
NVIDIA_MODEL=z-ai/glm-5.1
